<Window x:Class="GestureControlApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Iris"
        Width="860" Height="680"
        MinWidth="860" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F13"
        FontFamily="Segoe UI">

    <Window.Resources>

        <SolidColorBrush x:Key="Bg"          Color="#0F0F13"/>
        <SolidColorBrush x:Key="Surface"     Color="#1A1A22"/>
        <SolidColorBrush x:Key="Surface2"    Color="#22222E"/>
        <SolidColorBrush x:Key="Border"      Color="#2E2E3E"/>
        <SolidColorBrush x:Key="Accent"      Color="#7C6EF5"/>
        <SolidColorBrush x:Key="AccentDim"   Color="#3D3670"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#F0EFF8"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#5E5E78"/>
        <SolidColorBrush x:Key="TextSub"     Color="#9090AC"/>
        <SolidColorBrush x:Key="Green"       Color="#4ADE80"/>
        <SolidColorBrush x:Key="Red"         Color="#F87171"/>
        <SolidColorBrush x:Key="Orange"      Color="#FB923C"/>

        <Style x:Key="TabBtn" TargetType="RadioButton">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="{StaticResource TextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Height"       Value="36"/>
            <Setter Property="Padding"      Value="18,0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="6"
                                    Margin="2,4"/>
                            <Border x:Name="Indicator" Height="2" VerticalAlignment="Bottom"
                                    Margin="10,0" Background="Transparent" CornerRadius="1"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Indicator" Property="Background"
                                        Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="#22222E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <Style x:Key="GName" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="GDesc" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSub}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding"      Value="7,3"/>
            <Setter Property="Margin"       Value="0,0,0,10"/>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Height"           Value="38"/>
            <Setter Property="MinWidth"         Value="110"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#9081F7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#2E2E3E"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#C0392B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E74C3C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{StaticResource Surface2}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSub}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2E2E3E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PathBox" TargetType="TextBox">
            <Setter Property="Background"       Value="{StaticResource Surface2}"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush"       Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontSize"         Value="11"/>
            <Setter Property="Height"           Value="30"/>
            <Setter Property="Padding"          Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Sep" TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource Border}"/>
            <Setter Property="Margin"     Value="0,8"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="56"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="IRIS" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Gesture · Voice · Writing" FontSize="10"
                               Foreground="{StaticResource TextMuted}" Margin="1,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,4,0">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,7,0"
                             Fill="{StaticResource TextMuted}"/>
                    <TextBlock x:Name="HeaderStatus" Text="Idle"
                               FontSize="11" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="16,0">
                <RadioButton x:Name="TabReference" Content="Gesture Reference"
                             Style="{StaticResource TabBtn}" GroupName="Tabs"
                             IsChecked="True" Checked="Tab_Checked"/>
                <RadioButton x:Name="TabWriting" Content="Writing Mode"
                             Style="{StaticResource TabBtn}" GroupName="Tabs"
                             Checked="Tab_Checked"/>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="PanelReference" Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Background="{StaticResource Bg}"
                      Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource Surface}"
                        CornerRadius="10" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="3" CornerRadius="2" Background="#2563EB" Margin="0,0,10,0"/>
                            <TextBlock Text="Mouse Mode" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>

                        <TextBlock Text="RIGHT HAND" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource Pill}" Background="#1E2A4A">
                            <TextBlock Text="Cursor Control" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#60A5FA" HorizontalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Thumb + Index" Style="{StaticResource GName}"/>
                        <TextBlock Text="Left click" Style="{StaticResource GDesc}" Margin="0,1,0,8"/>
                        <TextBlock Text="Thumb + Middle" Style="{StaticResource GName}"/>
                        <TextBlock Text="Right click" Style="{StaticResource GDesc}" Margin="0,1,0,8"/>
                        <TextBlock Text="Thumb + Ring" Style="{StaticResource GName}"/>
                        <TextBlock Text="Enter" Style="{StaticResource GDesc}" Margin="0,1,0,8"/>
                        <TextBlock Text="Thumb left" Style="{StaticResource GName}"/>
                        <TextBlock Text="← Arrow key" Style="{StaticResource GDesc}" Margin="0,1,0,14"/>

                        <Separator Style="{StaticResource Sep}"/>
                        <TextBlock Text="LEFT HAND" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource Pill}" Background="#162A1E">
                            <TextBlock Text="Actions" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#4ADE80" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Index + Middle up" Style="{StaticResource GName}"/>
                        <TextBlock Text="Scroll up" Style="{StaticResource GDesc}" Margin="0,1,0,8"/>
                        <TextBlock Text="Index only up" Style="{StaticResource GName}"/>
                        <TextBlock Text="Scroll down" Style="{StaticResource GDesc}" Margin="0,1,0,8"/>
                        <TextBlock Text="Thumb + Index" Style="{StaticResource GName}"/>
                        <TextBlock Text="Click &amp; drag" Style="{StaticResource GDesc}" Margin="0,1,0,8"/>
                        <TextBlock Text="Fist" Style="{StaticResource GName}"/>
                        <TextBlock Text="Alt + Tab (hold to cycle)" Style="{StaticResource GDesc}" Margin="0,1,0,8"/>
                        <TextBlock Text="Thumb + Pinky" Style="{StaticResource GName}"/>
                        <TextBlock Text="Backspace" Style="{StaticResource GDesc}" Margin="0,1,0,8"/>
                        <TextBlock Text="Thumb right" Style="{StaticResource GName}"/>
                        <TextBlock Text="→ Arrow key" Style="{StaticResource GDesc}" Margin="0,1,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource Surface}"
                        CornerRadius="10" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="3" CornerRadius="2" Background="#EA580C" Margin="0,0,10,0"/>
                            <TextBlock Text="Voice Mode" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>

                        <TextBlock Text="RIGHT HAND" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource Pill}" Background="#2A1E10">
                            <TextBlock Text="Transcribe" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#FB923C" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Index + Middle + Ring up" Style="{StaticResource GName}"/>
                        <TextBlock Text="Hold → record, release → transcribe (English)"
                                   Style="{StaticResource GDesc}" Margin="0,1,0,14"/>

                        <Separator Style="{StaticResource Sep}"/>
                        <TextBlock Text="LEFT HAND" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource Pill}" Background="#162A1E">
                            <TextBlock Text="Translate" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#4ADE80" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Index + Middle up" Style="{StaticResource GName}"/>
                        <TextBlock Text="Hold → Malayalam to English"
                                   Style="{StaticResource GDesc}" Margin="0,1,0,8"/>
                        <TextBlock Text="Middle + Ring + Pinky up" Style="{StaticResource GName}"/>
                        <TextBlock Text="Hold → English to Malayalam"
                                   Style="{StaticResource GDesc}" Margin="0,1,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="{StaticResource Surface}"
                        CornerRadius="10" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="3" CornerRadius="2" Background="{StaticResource Accent}"
                                    Margin="0,0,10,0"/>
                            <TextBlock Text="Writing Mode" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>

                        <TextBlock Text="SWITCH IN" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="Both hands: Ring + Pinky up" Style="{StaticResource GName}"/>
                        <TextBlock Text="Hold 1 second to activate Writing mode"
                                   Style="{StaticResource GDesc}" Margin="0,1,0,14"/>

                        <Separator Style="{StaticResource Sep}"/>
                        <TextBlock Text="DRAW" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource Pill}" Background="#1E1A38">
                            <TextBlock Text="Left Fist = Start / Confirm" FontSize="10"
                                       FontWeight="SemiBold" Foreground="#A78BFA"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Right index fingertip" Style="{StaticResource GName}"/>
                        <TextBlock Text="Draws letter on camera canvas"
                                   Style="{StaticResource GDesc}" Margin="0,1,0,8"/>
                        <TextBlock Text="Left fist (2nd time)" Style="{StaticResource GName}"/>
                        <TextBlock Text="Recognises letter → launches mapped app"
                                   Style="{StaticResource GDesc}" Margin="0,1,0,14"/>

                        <Separator Style="{StaticResource Sep}"/>
                        <TextBlock Text="CONFIGURE" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="Edit letter → app mappings in the Writing Mode tab above."
                                   Style="{StaticResource GDesc}"/>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>

        <Grid x:Name="PanelWriting" Grid.Row="2" Visibility="Collapsed"
              Background="{StaticResource Bg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                    Padding="20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Letter → App Mappings"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Draw a letter in Writing mode → the mapped app launches."
                                   FontSize="11" Foreground="{StaticResource TextMuted}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Save Mappings" Style="{StaticResource PrimaryBtn}"
                                Click="SaveMappings_Click"/>
                        <Button Content="Reset to Defaults" Style="{StaticResource GhostBtn}"
                                Margin="8,0,0,0" Click="ResetMappings_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,12">
                <ItemsControl x:Name="MappingsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="{StaticResource AccentDim}"
                                        CornerRadius="6" Height="30">
                                    <TextBlock Text="{Binding Letter}"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Grid.Column="1" Text="→" FontSize="13"
                                           Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>

                                <TextBox Grid.Column="2" Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PathBox}"/>

                                <TextBlock Grid.Column="4" Text="{Binding DisplayName}"
                                           Style="{StaticResource GDesc}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <Button Grid.Column="6" Content="…"
                                        Tag="{Binding Letter}"
                                        Height="30" Width="34"
                                        Style="{StaticResource GhostBtn}"
                                        FontSize="13"
                                        Click="Browse_Click"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2" Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                    Padding="20,10">
                <TextBlock x:Name="SaveHint"
                           Text="Changes are saved to mappings.json next to the launcher and loaded on next Start."
                           FontSize="11" Foreground="{StaticResource TextMuted}"/>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                Padding="24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="Ready"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"/>
                    <TextBlock x:Name="StatusSub"
                               Text="Press Start — Python process will launch"
                               FontSize="10" Foreground="{StaticResource TextMuted}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" x:Name="StartButton"
                        Content="▶  Start"
                        Style="{StaticResource PrimaryBtn}"
                        Click="StartButton_Click"/>

                <Button Grid.Column="3" x:Name="StopButton"
                        Content="■  Stop"
                        Style="{StaticResource DangerBtn}"
                        IsEnabled="False"
                        Click="StopButton_Click"/>
            </Grid>
        </Border>

    </Grid>
</Window>
